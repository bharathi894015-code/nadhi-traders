{
    "version": 2,
    "builds": [
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server/index.js"
        },
        {
            "src": "/admin/(.*)",
            "dest": "public/admin/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "public/js/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "public/css/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "public/images/$1"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "public/uploads/$1"
        },
        {
            "src": "/(.*)",
            "dest": "public/$1",
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "server/index.js"
        }
    ]
}